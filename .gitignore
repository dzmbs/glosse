# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.uv-cache/

# Glosse book library — raw EPUBs and images stay out; parsed state is committed for deploy
data/books/*.epub
data/books/*/images/
data/inbox/

# Allow the ingested book state (needed for Railway deploy)
!data/books/*/book.pkl
!data/books/*/chunks.pkl
!data/books/*/meta.json
!data/progress.json

# Node / Next.js (frontend/)
node_modules/
.next/
.vercel/
.turbo/
frontend/public/sitemap*.xml
frontend/next-env.d.ts.bak
frontend/.next/

# Local env
.env
.env.local
.env.*.local

# Editor
.vscode/
.idea/
.DS_Store

# Local agent tooling (skills, caches — per-developer, not code)
.agents/
.claude/
.pi/
skills-lock.json
