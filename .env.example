# Copy this to .env and fill in your values.

# Required: OpenAI API key for the agent and embeddings.
# WARNING: /api/guide has no rate limiting. Each call may incur LLM charges.
# Consider adding slowapi middleware before exposing this to the internet.
OPENAI_API_KEY=

# Optional: OpenRouter fallback key. If set, the agent falls back to
# meta-llama/llama-3.3-70b-instruct:free when OpenAI is unreachable.
OPENROUTER_API_KEY=

# Optional: override the data directory (default: data/ in the project root).
GLOSSE_DATA_DIR=

# Optional: comma-separated CORS origins the FastAPI server will accept.
# Default: http://localhost:3000,http://127.0.0.1:3000
GLOSSE_ALLOWED_ORIGIN=

# Optional: max EPUB upload size in bytes. Default: 104857600 (100 MB).
GLOSSE_MAX_UPLOAD_BYTES=
